<Window x:Class="ClaudePilotSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Desktop" Height="640" Width="980"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource CanvasBrush}" Icon="Assets/claude.ico"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Viewbox x:Name="FixedDpiViewbox"
             Stretch="Uniform"
             StretchDirection="Both"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">
        <Grid x:Name="DesignSurface" Width="980" Height="590" Background="{StaticResource SurfaceBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="202" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel" Grid.Column="0" Background="{StaticResource CanvasBrush}">
                <Grid Margin="16,18,14,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="66" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Width="28" Height="28" Source="Assets/claude-symbol-1280.png"
                               Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,0,0"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel Grid.Column="1" Margin="5,-1,0,0">
                            <TextBlock Text="Claude Desktop" FontFamily="{StaticResource BrandFont}"
                                       FontSize="17" FontWeight="Medium" Foreground="{StaticResource InkBrush}" />
                            <TextBlock Text="R3.5" FontSize="9.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="1,6,0,0" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="部署" Style="{StaticResource SidebarSectionLabel}" />

                    <StackPanel Grid.Row="2">
                        <Button x:Name="InstallButton" Content="一键安装"
                                Style="{StaticResource SidebarPrimaryButton}" Click="InstallButton_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="4" Text="维护" Style="{StaticResource SidebarSectionLabel}" />

                    <StackPanel Grid.Row="5">
                        <Button x:Name="RepairButton" Tag="↻" Content="修复 / 重装"
                                Style="{StaticResource SidebarButton}" Click="RepairButton_Click" />
                        <Button x:Name="DiagnosticsButton" Tag="↗" Content="导出诊断"
                                Style="{StaticResource SidebarButton}" Click="DiagnosticsButton_Click" />
                        <Button x:Name="UninstallButton" Tag="—" Content="安全卸载"
                                Style="{StaticResource SidebarButton}" Click="UninstallButton_Click" />
                        <Button x:Name="AdvancedButton" Tag="···" Content="高级操作"
                                Style="{StaticResource SidebarButton}" Click="AdvancedButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource BorderBrush}" />

            <Grid x:Name="MainWorkspace" Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                  Margin="28,22,28,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="92" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="部署 Claude Desktop" FontFamily="{StaticResource BrandFont}"
                           FontSize="24" FontWeight="Medium" Foreground="{StaticResource InkBrush}" />

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="29" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="部署准备" Style="{StaticResource SectionTitle}" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.08*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="数据目录" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DataRootBox" Grid.Column="0"
                                         ToolTip="工作文件、MCP、日志、备份和状态文件所在目录；Cowork 核心仍固定在 C 盘 Claude-3p 真实物理目录" />
                                <Button x:Name="BrowseButton" Grid.Column="1" Content="选择目录"
                                        Width="82" Margin="7,0,0,0" Click="BrowseButton_Click" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="DeepSeek API Key" Style="{StaticResource FieldLabel}" />
                            <PasswordBox x:Name="ApiKeyBox"
                                         ToolTip="输入仅在内存和 DPAPI 临时密文票据中短暂存在，不会写入日志或报告" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border Grid.Row="2" Background="{StaticResource BorderBrush}" />

                <Grid Grid.Row="3" Margin="0,15,0,11">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="安装状态" Style="{StaticResource SectionTitle}" />

                    <TabControl x:Name="ResultsTabs" Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <TabItem Header="结果">
                            <Grid Margin="0,7,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="结果" Margin="10,0"
                                               VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Grid.Column="1" Text="项目" Margin="10,0"
                                               VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                    <TextBlock Grid.Column="2" Text="说明" Margin="10,0"
                                               VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedInkBrush}" />
                                </Grid>
                                <Border Grid.Row="1" Background="{StaticResource BorderBrush}" />
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled" Focusable="False">
                                    <ItemsControl x:Name="ChecksList" ItemsSource="{Binding Checks}" Focusable="False">
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="{x:Type ContentPresenter}">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="34" Background="Transparent">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="ResultStatus" Grid.Column="0"
                                                               Text="{Binding DisplayStatus}" Margin="10,0"
                                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}" />
                                                    <TextBlock x:Name="ResultName" Grid.Column="1"
                                                               Text="{Binding Name}" Margin="10,0"
                                                               VerticalAlignment="Center" FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock x:Name="ResultDetail" Grid.Column="2"
                                                               Text="{Binding Detail}" Margin="10,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource InkBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="PASS">
                                                        <Setter TargetName="ResultStatus" Property="Foreground" Value="{StaticResource InkBrush}" />
                                                        <Setter TargetName="ResultName" Property="Foreground" Value="{StaticResource InkBrush}" />
                                                        <Setter TargetName="ResultDetail" Property="Foreground" Value="{StaticResource InkBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="INFO">
                                                        <Setter TargetName="ResultStatus" Property="Foreground" Value="{StaticResource InkBrush}" />
                                                        <Setter TargetName="ResultName" Property="Foreground" Value="{StaticResource InkBrush}" />
                                                        <Setter TargetName="ResultDetail" Property="Foreground" Value="{StaticResource InkBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="WARN">
                                                        <Setter TargetName="ResultStatus" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="ResultName" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="ResultDetail" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="MANUAL">
                                                        <Setter TargetName="ResultStatus" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="ResultName" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="ResultDetail" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="FAIL">
                                                        <Setter TargetName="ResultStatus" Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                        <Setter TargetName="ResultName" Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                        <Setter TargetName="ResultDetail" Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                        <TabItem Header="安装过程">
                            <TextBox x:Name="LogBox" Style="{StaticResource DocumentTextBox}" Margin="0,7,0,0"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="11.5" />
                        </TabItem>
                        <TabItem Header="详细信息">
                            <TextBox x:Name="ReportBox" Style="{StaticResource DocumentTextBox}" Margin="0,7,0,0"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="11.5" />
                        </TabItem>
                        <TabItem Header="安装内容">
                            <TextBox x:Name="PreviewBox" Style="{StaticResource DocumentTextBox}" Margin="0,7,0,0"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                     FontSize="11.5" TextBlock.LineHeight="20"
                                     Text="一键安装会自动检查电脑、完成安装，再做安装后复核。&#x0a;&#x0a;只有出现红色问题时，才需要手动处理。" />
                        </TabItem>
                    </TabControl>
                </Grid>

                <Border Grid.Row="4" Background="{StaticResource BorderBrush}" />

                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="进度" Foreground="{StaticResource MutedInkBrush}" FontSize="10.5"
                               FontWeight="SemiBold" VerticalAlignment="Center" />
                    <ProgressBar x:Name="ProgressBar" Grid.Column="1" Minimum="0" Maximum="100"
                                 Value="0" Margin="12,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="ProgressText" Grid.Column="2" Text="0%" Foreground="{StaticResource InkBrush}"
                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                               MinWidth="32" TextAlignment="Right" />
                </Grid>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
