<Window x:Class="ClaudePilotSetup.AdvancedOperationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Desktop - 高级操作"
        Width="580" Height="390" MinWidth="580" MinHeight="390"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource CanvasBrush}" Icon="Assets/claude.ico"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid Margin="26,18,26,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="高级操作" FontFamily="{StaticResource BrandFont}"
                   FontSize="23" FontWeight="Medium" />

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="26" />
                <RowDefinition Height="42" />
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="选择操作" FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <RadioButton x:Name="ForceReinstallRadio" Grid.Row="1"
                         GroupName="Operation" IsChecked="True"
                         Checked="OperationRadio_Changed"
                         FocusVisualStyle="{x:Null}"
                         HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                <Grid Margin="8,0,0,0">
                    <TextBlock Text="彻底重装" FontSize="13" FontWeight="SemiBold" />
                </Grid>
            </RadioButton>

            <RadioButton x:Name="PreserveUninstallRadio" Grid.Row="2"
                         GroupName="Operation" Checked="OperationRadio_Changed"
                         FocusVisualStyle="{x:Null}"
                         HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                <Grid Margin="8,0,0,0">
                    <TextBlock Text="完全卸载" FontSize="13" FontWeight="SemiBold" />
                </Grid>
            </RadioButton>

            <StackPanel Grid.Row="3">
                <RadioButton x:Name="FullCleanupRadio" GroupName="Operation"
                             Height="42" Checked="OperationRadio_Changed"
                             FocusVisualStyle="{x:Null}"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                    <Grid Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="清除全部数据" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="不可恢复" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource DangerBrush}" />
                    </Grid>
                </RadioButton>
                <CheckBox x:Name="DeleteAcknowledgementCheckBox" Margin="27,0,0,8"
                          Visibility="Collapsed" IsEnabled="False" FontSize="10.5"
                          FocusVisualStyle="{x:Null}"
                          Content="我确认删除 Cowork 文件和整个数据目录"
                          Checked="DeleteAcknowledgement_Changed" Unchecked="DeleteAcknowledgement_Changed" />
            </StackPanel>

            <StackPanel Grid.Row="5">
                <TextBlock Text="附加清理" FontSize="12" FontWeight="SemiBold" />
                <WrapPanel Margin="0,10,0,0">
                    <CheckBox x:Name="RemoveGitCheckBox" Content="Git" Margin="0,0,24,0"
                              FocusVisualStyle="{x:Null}" />
                    <CheckBox x:Name="DisableVmpCheckBox" Content="VirtualMachinePlatform"
                              FocusVisualStyle="{x:Null}" />
                </WrapPanel>
                <TextBlock x:Name="OwnershipText" Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Margin="0,0,8,0" Click="CancelButton_Click" />
            <Button x:Name="ContinueButton" Content="继续" Style="{StaticResource PrimaryButton}"
                    Margin="0" Click="ContinueButton_Click" />
        </StackPanel>
    </Grid>
</Window>
