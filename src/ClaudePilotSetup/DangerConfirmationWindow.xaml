<Window x:Class="ClaudePilotSetup.DangerConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认清除全部数据"
        Width="650" Height="430" MinWidth="600" MinHeight="390"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource CanvasBrush}" Icon="Assets/claude.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="这是不可恢复的数据删除操作" FontFamily="{StaticResource BrandFont}" FontSize="24" FontWeight="Medium"
                       Foreground="{StaticResource DangerBrush}" />
            <TextBlock Text="安装程序将删除下面整个受管目录，包括其中的 Cowork 工作文件。"
                       Foreground="{StaticResource MutedInkBrush}" FontSize="12.5" Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource DangerSoftBrush}" BorderBrush="#EDC9C3"
                BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,18,0,16">
            <StackPanel>
                <TextBlock Text="将被删除的数据目录" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" />
                <TextBox x:Name="DataRootTextBox" IsReadOnly="True" Margin="0,9,0,0" />
                <TextBlock Margin="0,16,0,7" TextWrapping="Wrap">
                    <Run Text="如确认继续，请输入 " />
                    <Run Text="彻底清理" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" />
                </TextBlock>
                <TextBox x:Name="ConfirmationTextBox" TextChanged="ConfirmationTextBox_TextChanged" />
                <TextBlock Text="不会自动撤销 DeepSeek 后台 Key；设备退役后仍需在 DeepSeek 后台撤销。"
                           FontSize="11.5" Foreground="{StaticResource WarningBrush}" Margin="0,13,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Click="CancelButton_Click" />
            <Button x:Name="ConfirmButton" Content="确认清除" Style="{StaticResource DangerButton}"
                    Margin="0" IsEnabled="False" Click="ConfirmButton_Click" />
        </StackPanel>
    </Grid>
</Window>
